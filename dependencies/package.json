{
  "name": "@rupertsworld/dependencies",
  "version": "0.2.0",
  "type": "module",
  "description": "Lazy singleton dependency container with typed identifiers and injectable classes",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "example": "npm --prefix example run dev",
    "example:build": "npm --prefix example run build",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:types": "tsc --noEmit --project tsconfig.test.json",
    "test:all": "npm run test && npm run test:types"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
